# Copy this file to secrets.toml and fill in your values.
# DO NOT commit secrets.toml to git.

[supabase]
url = "https://YOUR-PROJECT.supabase.co"
anon_key = "eyJ...your anon public key..."
service_key = "eyJ...your service_role key (server-side only)..."
storage_bucket = "company-assets"

[app]
# Used to seed the first admin user on initial run, if no users exist.
initial_admin_email = "you@example.com"
initial_admin_password = "ChangeMeNow!"
initial_admin_name = "Admin"

# Optional: app branding
app_title = "HR Letters"
